# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# In development, if this URI fails, an in-process MongoMemoryServer starts automatically.
# For production or persistence, use a real MongoDB URI (local or Atlas).
MONGODB_URI=mongodb://127.0.0.1:27017/threatlens

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# EMAIL (for password reset — optional in dev)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@threatlens.local

# ─────────────────────────────────────────────
# THREAT INTEL API KEYS (server-side only)
# ─────────────────────────────────────────────
VIRUSTOTAL_API_KEY=
MALWAREBAZAAR_API_KEY=
HYBRID_ANALYSIS_API_KEY=
URLSCAN_API_KEY=
# ThreatMiner requires no key
ABUSEIPDB_API_KEY=

# ─────────────────────────────────────────────
# AI PROVIDER (optional — leave blank for template fallback)
# ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=template   # template | openai | anthropic

# ─────────────────────────────────────────────
# FILE UPLOAD
# ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=32
UPLOAD_DIR=./uploads
